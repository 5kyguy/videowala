# Dev mode (optional; default = real models)
# - Omit or set false: VLM/OCR/ASR/embeddings use real integrations (GPU preferred where available).
# - DEV_MODE=true: deterministic stubs only (no GPU; tests / CI friendly).
# DEV_MODE=true

# Postgres for pgvector semantic search (used when DEV_MODE=false; best-effort if DB is down).
# Keep PG_DSN in sync with POSTGRES_* when using backend/docker-compose.yml (host port = POSTGRES_PORT).
POSTGRES_DB=videowala
POSTGRES_USER=videowala
POSTGRES_PASSWORD=videowala
POSTGRES_PORT=5432
PG_DSN=postgresql://videowala:videowala@localhost:5432/videowala

# VLM checkpoint to use when DEV_MODE=false (Qwen2.5-VL; requires qwen-vl-utils + transformers>=4.48)
VLM_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct

# Embedding model when DEV_MODE=false (gte-Qwen2; trust_remote_code; must match pgvector dim)
EMBEDDING_MODEL_ID=Alibaba-NLP/gte-Qwen2-7B-instruct
EMBEDDING_VECTOR_DIM=3584

# VLM tags (lowercase) that trigger Paddle OCR after captioning (comma-separated)
# OCR_TRIGGER_TAGS=text,signage,document,readable_text

# Index jobs: thread pool size (default 1 = serial indexing for PoC)
# INDEX_WORKERS=1

# When POST /assets includes semantic_prompt for images, cull fraction for photo ranking (0–1)
# IMAGE_INDEX_SEMANTIC_CULL_PERCENT=0.5
