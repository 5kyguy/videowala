# Dev mode (optional; default = real models)
# - Omit or set false: VLM/OCR/ASR/embeddings use real integrations (GPU preferred where available).
# - DEV_MODE=true: deterministic stubs only (no GPU; tests / CI friendly).
# DEV_MODE=true

# Model provider for VLM + embeddings + planner LLM.
# - transformers: load models via HuggingFace transformers / sentence-transformers (current default)
# - ollama: call the local Ollama HTTP API (requires Ollama server + models present)
MODEL_PROVIDER=ollama

# If MODEL_PROVIDER=ollama:
# - OLLAMA_BASE_URL: where your Ollama server listens
# - OLLAMA_VLM_MODEL_ID: vision model name (caption + tags)
# - OLLAMA_EMBEDDING_MODEL_ID: embedding model name
# - OLLAMA_PLANNER_MODEL_ID: text model name for segment reordering
# - OLLAMA_KEEP_ALIVE_STAGE: e.g. 5m (models stay warm during a stage; unlock uses keep_alive=0)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_VLM_MODEL_ID=qwen2.5vl
# OLLAMA_EMBEDDING_MODEL_ID=embeddinggemma
# OLLAMA_PLANNER_MODEL_ID=llama3.1
# OLLAMA_KEEP_ALIVE_STAGE=5m

# Optional: additional CUDA library directories (colon-separated) used by ASR runtime
# to locate libcublas.so.12 when it is installed outside the default linker path.
# Example:
# CUDA_LIBRARY_PATHS=/usr/local/cuda/lib64:/usr/lib/x86_64-linux-gnu
# CUDA_LIBRARY_PATHS=

# Postgres for pgvector semantic search (used when DEV_MODE=false; best-effort if DB is down).
# Keep PG_DSN in sync with POSTGRES_* when using backend/docker-compose.yml (host port = POSTGRES_PORT).
POSTGRES_DB=videowala
POSTGRES_USER=videowala
POSTGRES_PASSWORD=videowala
POSTGRES_PORT=5432
PG_DSN=postgresql://videowala:videowala@localhost:5432/videowala

# pgvector embedding vector dimension (must match what your Ollama embedding model returns).
EMBEDDING_VECTOR_DIM=3584

# VLM tags (lowercase) that trigger Paddle OCR after captioning (comma-separated)
# OCR_TRIGGER_TAGS=text,signage,document,readable_text

# Index jobs: thread pool size (default 1 = serial indexing for PoC)
# INDEX_WORKERS=1
# When using MODEL_PROVIDER=ollama, keep INDEX_WORKERS=1 (Ollama unload is global to the Ollama server).

# When POST /assets includes semantic_prompt for images, cull fraction for photo ranking (0–1)
# IMAGE_INDEX_SEMANTIC_CULL_PERCENT=0.5

# Planner (segment reordering) tuning when `PLANNER_MODEL_ENABLED=true`:
# - Uses `OLLAMA_PLANNER_MODEL_ID` in Ollama mode
# - `PLANNER_MODEL_ENABLED` defaults to true if unset
# PLANNER_MAX_SEGMENTS=80
# PLANNER_TEMPERATURE=0.2
# PLANNER_MAX_NEW_TOKENS=4096
