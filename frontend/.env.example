# API base URL as seen by the **browser** (see also VITE_API_PROXY_TARGET).
#
# - http://localhost:8000 — call FastAPI directly (typical local HTTP dev).
# - /api — same-origin requests; Vite proxies /api → FastAPI (see vite.config.ts).
#   Use this when the UI is served over HTTPS (e.g. ngrok) so the browser does not
#   block mixed content (HTTPS page → HTTP API).
VITE_API_BASE_URL=http://localhost:8000
#
# Backend origin for the dev/preview proxy only (when VITE_API_BASE_URL=/api).
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Ngrok (or similar) hostname for the Vite dev server only — no scheme, no path.
# Example: abc123.ngrok-free.app
# When set, Vite allows that Host, fixes HMR over wss, and listens on 0.0.0.0:5173.
# Leave unset for normal localhost-only dev.
# VITE_DEV_PUBLIC_HOST=abc123.ngrok-free.app
